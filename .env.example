# Cloudinary Configuration
# Obtén estos valores de: https://cloudinary.com/console/settings/api-keys

# Tu Cloud Name (encontrado en tu dashboard de Cloudinary)
VITE_CLOUDINARY_CLOUD_NAME=tu_cloud_name_aqui

# Tu Upload Preset (debe ser sin autenticación requerida)
# Créalo en: https://cloudinary.com/console/settings/upload
VITE_CLOUDINARY_UPLOAD_PRESET=tu_upload_preset_aqui

# Backend API Configuration
# URL del servidor de backend (FastAPI)
VITE_API_URL=http://localhost:8000
